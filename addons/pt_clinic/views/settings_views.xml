<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_config_settings_pt_clinic" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.pt.clinic</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
        <app string="وقاية" name="pt_clinic_settings">
                    <block title="التذكيرات | Reminders">
                        <setting string="موعد التذكير | Reminder Lead Time" help="How many hours before appointment reminder is sent.">
                            <field name="pt_reminder_hours_before"/>
                        </setting>
                        <setting string="رابط SMS Gateway" help="Optional HTTP endpoint that receives JSON payload: channel,to,message.">
                            <field name="pt_sms_gateway_url" placeholder="https://provider.example/send-sms"/>
                        </setting>
                        <setting string="رابط WhatsApp Gateway" help="Optional HTTP endpoint that receives JSON payload: channel,to,message.">
                            <field name="pt_whatsapp_gateway_url" placeholder="https://provider.example/send-whatsapp"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="view_pt_reminder_log_list" model="ir.ui.view">
        <field name="name">pt.reminder.log.list</field>
        <field name="model">pt.reminder.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="create_date"/>
                <field name="appointment_id"/>
                <field name="patient_id"/>
                <field name="channel"/>
                <field name="recipient"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_pt_reminder_log_form" model="ir.ui.view">
        <field name="name">pt.reminder.log.form</field>
        <field name="model">pt.reminder.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="appointment_id"/>
                        <field name="patient_id"/>
                        <field name="channel"/>
                        <field name="recipient"/>
                        <field name="status"/>
                    </group>
                    <group>
                        <field name="payload"/>
                        <field name="response_text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pt_reminder_logs" model="ir.actions.act_window">
        <field name="name">سجل التذكيرات | Reminder Logs</field>
        <field name="res_model">pt.reminder.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

