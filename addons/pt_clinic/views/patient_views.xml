<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pt_patient_search" model="ir.ui.view">
        <field name="name">pt.patient.search</field>
        <field name="model">pt.patient</field>
        <field name="arch" type="xml">
            <search string="Search Patients">
                <field name="name"/>
                <field name="code"/>
                <field name="phone"/>
                <field name="whatsapp"/>
                <field name="national_id"/>
                <field name="branch_id"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Branch" name="group_branch" context="{'group_by': 'branch_id'}"/>
                    <filter string="Gender" name="group_gender" context="{'group_by': 'gender'}"/>
                    <filter string="Governorate" name="group_governorate" context="{'group_by': 'governorate'}"/>
                    <filter string="Employer" name="group_company" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_pt_patient_tree" model="ir.ui.view">
        <field name="name">pt.patient.tree</field>
        <field name="model">pt.patient</field>
        <field name="arch" type="xml">
            <list decoration-muted="not active">
                <field name="code"/>
                <field name="name"/>
                <field name="age_years"/>
                <field name="national_id"/>
                <field name="phone"/>
                <field name="branch_id"/>
                <field name="company_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_pt_patient_form" model="ir.ui.view">
        <field name="name">pt.patient.form</field>
        <field name="model">pt.patient</field>
        <field name="arch" type="xml">
            <form string="Patient" class="o_pt_clinic_touch_form">
                <sheet>
                    <group>
                        <group>
                            <field name="code" readonly="1"/>
                            <field name="name"/>
                            <field name="partner_id"/>
                            <field name="birth_date"/>
                            <field name="age_years" readonly="1"/>
                            <field name="gender"/>
                            <field name="national_id"/>
                            <field name="governorate"/>
                        </group>
                        <group>
                            <field name="clinic_company_id" groups="base.group_multi_company"/>
                            <field name="branch_id"/>
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="whatsapp"/>
                            <field name="job_title"/>
                            <field name="primary_physician"/>
                            <field name="company_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="emergency_contact"/>
                            <field name="emergency_relation"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Medical">
                            <group>
                                <field name="medical_history"/>
                                <field name="allergy_notes"/>
                            </group>
                        </page>
                        <page string="Appointments">
                            <field name="appointment_ids"/>
                        </page>
                        <page string="Assessments">
                            <field name="assessment_ids"/>
                        </page>
                        <page string="Care Plans">
                            <field name="treatment_plan_ids"/>
                        </page>
                        <page string="Sessions">
                            <field name="session_ids"/>
                        </page>
                        <page string="Therapy Sheets">
                            <field name="therapy_sheet_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pt_patient_kanban" model="ir.ui.view">
        <field name="name">pt.patient.kanban</field>
        <field name="model">pt.patient</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="code"/>
                <field name="name"/>
                <field name="phone"/>
                <field name="whatsapp"/>
                <field name="branch_id"/>
                <field name="age_years"/>
                <templates>
                    <t t-name="card">
                        <div class="o_pt_clinic_mobile_card">
                            <div class="o_pt_clinic_card_title"><field name="name"/></div>
                            <div class="o_pt_clinic_card_meta"><span class="badge text-bg-primary"><field name="code"/></span></div>
                            <div class="o_pt_clinic_card_meta" t-if="record.phone.raw_value"><i class="fa fa-phone"/> <field name="phone"/></div>
                            <div class="o_pt_clinic_card_meta" t-if="record.whatsapp.raw_value"><i class="fa fa-whatsapp"/> <field name="whatsapp"/></div>
                            <div class="o_pt_clinic_card_footer">
                                <span t-if="record.age_years.raw_value" class="badge text-bg-light"><field name="age_years"/> yrs</span>
                                <span t-if="record.branch_id.raw_value" class="badge text-bg-light"><field name="branch_id"/></span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_pt_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">pt.patient</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_pt_patient_search"/>
    </record>
</odoo>
