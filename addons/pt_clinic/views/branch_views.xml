<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pt_branch_list" model="ir.ui.view">
        <field name="name">pt.branch.list</field>
        <field name="model">pt.branch</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="clinic_company_id"/>
                <field name="manager_id"/>
                <field name="phone"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_pt_branch_form" model="ir.ui.view">
        <field name="name">pt.branch.form</field>
        <field name="model">pt.branch</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="clinic_company_id"/>
                            <field name="manager_id"/>
                        </group>
                        <group>
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="address"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pt_branch" model="ir.actions.act_window">
        <field name="name">Branches</field>
        <field name="res_model">pt.branch</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

